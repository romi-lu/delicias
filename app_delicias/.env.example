# --- Desarrollo local (misma WiFi que el PC que corre Nest en :6002) ---
# API_HOST=192.168.1.50
# API_PORT=6002

# --- Producción (Railway u otro HTTPS): misma URL que BACKEND_URL en Next (solo el Nest) ---
# Sin barra final, sin /api (la app usa .../api/productos, .../uploads/...).
# Tras cambiar .env: detén la app y vuelve a ejecutar flutter run (no basta hot reload).
# API_BASE_URL=https://tu-backend-production-xxxx.up.railway.app
#
# Alternativa sin tocar .env:
# flutter run --dart-define=API_BASE_URL=https://tu-backend-xxxx.up.railway.app
