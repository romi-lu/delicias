# Copia a .env y rellena. Los nombres deben coincidir con Railway → Variables (servicio backend).

PORT=6002

# Supabase: Settings → Database → Connection string → Transaction (puerto 6543, host *pooler*)
DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

JWT_SECRET=genera_un_secreto_largo_aleatorio

