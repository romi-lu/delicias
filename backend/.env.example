# Copia a .env y rellena. Los nombres deben coincidir con Railway → Variables (servicio backend).

PORT=6002

# Supabase: Settings → Database → Connection string → modo "Transaction" (pooler :6543, NO db.*.supabase.co:5432 desde Railway).
# Con Prisma + pooler suele hacer falta pgbouncer=true. Codifica la contraseña si tiene @ # % etc.
# Ejemplo (ajusta usuario/host según lo que copie el dashboard):
DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

JWT_SECRET=genera_un_secreto_largo_aleatorio

# DECOLECTA_BASE_URL=
# DECOLECTA_TOKEN=

# ADMIN_EMAIL=
# ADMIN_PASSWORD=

UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880
